# Required
DISCORD_BOT_TOKEN=your_discord_bot_token
COINGLASS_API_KEY=your_coinglass_api_key

# Optional safety controls
# Comma-separated Discord user IDs. Leave empty to allow everyone in allowed channels.
ALLOWED_USER_IDS=
# Comma-separated Discord channel IDs. Leave empty to allow all channels the bot can read.
ALLOWED_CHANNEL_IDS=

# Message behavior
# Supports: bare symbols like btc, and command forms like !cg btc or cg btc.
ALLOW_BARE_SYMBOL=true
COMMAND_PREFIXES=!cg,cg,/cg

# Futures defaults
DEFAULT_EXCHANGE=Binance
DEFAULT_QUOTE=USDT
DEFAULT_INTERVAL=4h
HISTORY_LIMIT=60
AGGREGATED_EXCHANGES=Binance,OKX,Bybit
LIQUIDATION_RANGE=24h

# Exchange supplement
# Adds Binance USD-M public data: 24h ticker, mark/index, order book, 15m klines, 15m OI, 15m long/short ratios.
ENABLE_EXCHANGE_SUPPLEMENT=true
SECONDARY_INTERVAL=15m
SECONDARY_LIMIT=96
ORDER_BOOK_LIMIT=100

# Runtime tuning
COINGLASS_CONCURRENCY=3
REQUEST_TIMEOUT_MS=20000
